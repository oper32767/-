{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/fourarts/gate_schema.json",
  "title": "FourArts Validation Gate",
  "type": "object",
  "additionalProperties": false,
  "required": ["gate_id", "gate_name", "applies_to", "severity", "condition", "on_trigger", "reviewer", "status"],
  "properties": {
    "gate_id": {"type": "string", "minLength": 1},
    "gate_name": {"type": "string", "minLength": 1},
    "applies_to": {"type": "array", "minItems": 1, "items": {"type": "string", "enum": ["STATIC", "DYNAMIC", "BAZI", "ZIWEI", "LIUREN", "QIMEN", "INTEGRATED", "ALL"]}},
    "severity": {"type": "string", "enum": ["WARN", "BLOCK"]},
    "condition": {"type": "string", "minLength": 1},
    "on_trigger": {"type": "string", "minLength": 1},
    "source_ref": {"type": ["string", "null"]},
    "reviewer": {"type": "string", "minLength": 1},
    "status": {"type": "string", "enum": ["ACTIVE", "RETIRED", "DRAFT"]},
    "unknown_policy": {"type": "string", "enum": ["PRESERVE", "WARN", "BLOCK"]},
    "notes": {"type": ["string", "null"]}
  }
}
